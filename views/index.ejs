<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SESC Alertas - Painel de Controle</title>
  <link rel="stylesheet" href="/css/style.css">
</head>

<body>
  <div class="container">
    <header>
      <h1>🎭 SESC Alertas</h1>
      <p class="subtitle">Painel de Gerenciamento e Execução</p>
    </header>

    <div class="status-bar">
      <div class="status-item">
        <span class="label">Status:</span>
        <span class="value <%= isRunning ? 'running' : 'idle' %>" id="status">
          <%= isRunning ? '🔄 Executando...' : '✅ Ocioso' %>
        </span>
      </div>
      <% if (lastExecution) { %>
        <div class="status-item">
          <span class="label">Última Execução:</span>
          <span class="value">
            <%= new Date(lastExecution.startTime).toLocaleString('pt-BR') %>
              (<%= lastExecution.success ? '✅ Sucesso' : '❌ Falha' %>)
          </span>
        </div>
        <% } %>
    </div>

    <div class="tabs">
      <button class="tab-btn active" data-tab="config">⚙️ Configurações</button>
      <button class="tab-btn" data-tab="execution">▶️ Execução</button>
      <button class="tab-btn" data-tab="logs">📋 Logs</button>
    </div>

    <!-- Tab Configurações -->
    <div class="tab-content active" id="config-tab">
      <h2>Configurações</h2>
      <form id="config-form">
        <div class="form-group">
          <label for="telegramToken">🤖 Telegram Bot Token:</label>
          <input type="text" id="telegramToken" name="telegramToken" value="<%= config.telegramToken %>" required>
        </div>

        <div class="form-group">
          <label for="telegramChatId">💬 Telegram Chat ID:</label>
          <input type="text" id="telegramChatId" name="telegramChatId" value="<%= config.telegramChatId %>" required>
        </div>

        <div class="form-group">
          <label for="geminiApiKey">🤖 Gemini API Key:</label>
          <input type="password" id="geminiApiKey" name="geminiApiKey" value="<%= config.geminiApiKey %>" required>
          <button type="button" class="btn-small" onclick="togglePassword('geminiApiKey')">👁️ Mostrar</button>
        </div>

        <div class="form-group">
          <label for="urlPagina">🔗 URL da Página SESC:</label>
          <input type="url" id="urlPagina" name="urlPagina" value="<%= config.urlPagina %>" required>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="maxRounds">🔄 Máximo de Rodadas:</label>
            <input type="number" id="maxRounds" name="maxRounds" value="<%= config.maxRounds %>" min="1" max="20"
              required>
            <small>Número de tentativas de extração com IA</small>
          </div>

          <div class="form-group">
            <label for="geminiModel">🧠 Modelo Gemini:</label>
            <input type="text" id="geminiModel" name="geminiModel" value="<%= config.geminiModel %>" required>
            <small>Ex: gemini-3-flash-preview</small>
          </div>
        </div>

        <hr style="margin: 20px 0; border-top: 1px solid #e9ecef;">
        <h3>🟢 WhatsApp (Evolution API)</h3>
        
        <div class="form-group">
          <label for="evolutionApiUrl">🔗 URL da API:</label>
          <input type="url" id="evolutionApiUrl" name="evolutionApiUrl" 
                 value="<%= config.evolutionApiUrl %>" placeholder="https://api.sua-evolution.com">
        </div>

        <div class="form-group">
          <label for="evolutionApiKey">🔑 API Key:</label>
          <input type="password" id="evolutionApiKey" name="evolutionApiKey" 
                 value="<%= config.evolutionApiKey %>">
          <button type="button" class="btn-small" onclick="togglePassword('evolutionApiKey')">👁️ Mostrar</button>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="evolutionApiInstance">⚙️ Instância:</label>
            <input type="text" id="evolutionApiInstance" name="evolutionApiInstance" 
                   value="<%= config.evolutionApiInstance %>" placeholder="nome_da_instancia">
          </div>

          <div class="form-group">
            <label for="whatsappNumber">📱 Número Destino:</label>
            <input type="text" id="whatsappNumber" name="whatsappNumber" 
                   value="<%= config.whatsappNumber %>" placeholder="5511999999999 ou id_do_grupo">
          </div>
        </div>

        <button type="submit" class="btn btn-primary">💾 Salvar Configurações</button>
      </form>
    </div>

    <!-- Tab Execução -->
    <div class="tab-content" id="execution-tab">
      <h2>Seleção de Unidades SESC</h2>

      <div class="units-section">
        <div class="units-header">
          <p>Selecione quais unidades SESC você deseja monitorar:</p>
          <button id="extract-units-btn" class="btn btn-secondary">
            🔍 Extrair Unidades do PDF
          </button>
        </div>

        <div id="units-loading" class="units-loading" style="display: none;">
          <div class="spinner"></div>
          <p>Analisando PDF e extraindo unidades... Aguarde...</p>
        </div>

        <div id="units-container" class="units-container">
          <% if (availableUnits && availableUnits.length> 0) { %>
            <div class="units-grid">
              <% availableUnits.forEach(unit=> { %>
                <label class="unit-checkbox">
                  <input type="checkbox" name="unit" value="<%= unit %>" <%=selectedUnits.includes(unit) ? 'checked'
                    : '' %>>
                  <span>
                    <%= unit %>
                  </span>
                </label>
                <% }) %>
            </div>
            <div class="units-actions">
              <button id="select-all-btn" class="btn btn-small">✅ Selecionar Todas</button>
              <button id="deselect-all-btn" class="btn btn-small">❌ Desmarcar Todas</button>
              <button id="save-units-btn" class="btn btn-primary">💾 Salvar Seleção</button>
            </div>
            <% } else { %>
              <p class="no-units">Clique em "Extrair Unidades do PDF" para começar.</p>
              <% } %>
        </div>
      </div>

      <hr style="margin: 30px 0; border: 1px solid #e9ecef;">

      <h2>Execução Manual</h2>
      <div class="execution-panel">
        <p>Execute o script de extração de eventos do SESC manualmente.</p>
        <% if (selectedUnits && selectedUnits.length> 0) { %>
          <p class="selected-units-info">
            <strong>📍 Unidades selecionadas:</strong>
            <%= selectedUnits.join(', ') %>
          </p>
        <% } %>
        <button id="execute-btn" class="btn btn-success" <%= isRunning ? ' disabled' : '' %>>
              ▶️ Executar Agora
              </button>
              <div id="execution-status" class="execution-status"></div>
      </div>

      <div class="info-box">
        <h3>ℹ️ Como funciona:</h3>
        <ol>
          <li>Extraia as unidades disponíveis do PDF</li>
          <li>Selecione quais unidades deseja monitorar</li>
          <li>Salve a seleção</li>
          <li>Execute o script para extrair eventos apenas das unidades selecionadas</li>
          <li>Receba notificação formatada no Telegram</li>
        </ol>
      </div>
    </div>

    <!-- Tab Logs -->
    <div class="tab-content" id="logs-tab">
      <div class="logs-header">
        <h2>Logs de Execução</h2>
        <button id="clear-logs-btn" class="btn btn-small">🗑️ Limpar Logs</button>
      </div>
      <div class="logs-container" id="logs-container">
        <% if (logs && logs.length> 0) { %>
          <% logs.forEach(log=> { %>
            <div class="log-entry log-<%= log.type %>">
              <span class="log-time">
                <%= new Date(log.time).toLocaleTimeString('pt-BR') %>
              </span>
              <span class="log-message">
                <%= log.message %>
              </span>
            </div>
            <% }) %>
              <% } else { %>
                <p class="no-logs">Nenhum log disponível. Execute o script para ver os logs.</p>
                <% } %>
      </div>
    </div>
  </div>

  <script src="/js/main.js"></script>
</body>

</html>